---
import MobileMenuToggle from "virtual:starlight/components/MobileMenuToggle";

const { hasSidebar } = Astro.props;

const HELP_HREF = "https://www.newsfork.com/contact";
---

<div class="page sl-flex">
  <div class="header-strip" aria-hidden="true"></div>
  <header class="header"><slot name="header" /></header>
  {
    hasSidebar && (
      <nav class="sidebar" aria-label={Astro.locals.t("sidebarNav.accessibleLabel")}>
        <MobileMenuToggle {...Astro.props} />
        <div id="starlight__sidebar" class="sidebar-pane">
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>
  <a href={HELP_HREF} class="help-button" target="_blank" rel="noopener noreferrer" aria-label="Contact support">
    <span class="help-icon" aria-hidden="true">?</span>
    <span class="help-label">Help</span>
  </a>
</div>

<style>
  .page {
    flex-direction: column;
    min-height: 100vh;
  }

  .header-strip {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background-color: #0ea5e9;
    z-index: 11;
  }
  :global([data-theme="dark"]) .header-strip {
    background-color: #0284c7;
  }

  .header {
    z-index: var(--sl-z-index-navbar);
    position: fixed;
    inset-inline-start: 0;
    inset-block-start: 3px;
    width: 100%;
    height: var(--sl-nav-height);
    border-bottom: 1px solid var(--sl-color-hairline-shade);
    padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
    padding-inline-end: var(--sl-nav-pad-x);
    background-color: var(--sl-color-bg-nav);
  }

  :global([data-has-sidebar]) .header {
    padding-inline-end: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size));
  }

  .sidebar-pane {
    visibility: var(--sl-sidebar-visibility, hidden);
    position: fixed;
    z-index: var(--sl-z-index-menu);
    inset-block-start: calc(3px + var(--sl-nav-height));
    inset-block-end: 0;
    inset-inline-start: 0;
    width: 100%;
    background-color: var(--sl-color-black);
    overflow-y: auto;
  }

  :global([aria-expanded="true"]) ~ .sidebar-pane {
    --sl-sidebar-visibility: visible;
  }

  .sidebar-content {
    height: 100%;
    min-height: max-content;
    padding: 1rem var(--sl-sidebar-pad-x) 0;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 50rem) {
    .sidebar-content::after {
      content: "";
      padding-bottom: 1px;
    }
  }

  .main-frame {
    padding-top: calc(3px + var(--sl-nav-height) + var(--sl-mobile-toc-height));
    padding-inline-start: var(--sl-content-inline-start);
  }

  .help-button {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 999;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  .help-button:hover {
    background-color: #f9fafb;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12);
  }
  :global([data-theme="dark"]) .help-button {
    color: #e5e7eb;
    background-color: #1f2937;
    border-color: #374151;
  }
  :global([data-theme="dark"]) .help-button:hover {
    background-color: #374151;
  }

  .help-icon {
    width: 1.25rem;
    height: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: #e5e7eb;
    color: #374151;
    font-size: 0.75rem;
    font-weight: 600;
  }
  :global([data-theme="dark"]) .help-icon {
    background-color: #4b5563;
    color: #e5e7eb;
  }

  .help-label {
    white-space: nowrap;
  }

  @media (min-width: 50rem) {
    :global([data-has-sidebar]) .header {
      padding-inline-end: var(--sl-nav-pad-x);
    }
    .sidebar-pane {
      --sl-sidebar-visibility: visible;
      width: 20rem;
      min-width: 20rem;
      max-width: 20rem;
      background-color: var(--sl-color-bg-sidebar);
    }
  }

  @media (min-width: 50rem) {
    :global([data-has-sidebar]) .main-frame {
      padding-inline-start: 20rem;
    }
  }
</style>
