---
import MobileMenuToggle from "virtual:starlight/components/MobileMenuToggle";

const { hasSidebar } = Astro.props;

const CHAT_HREF = "https://www.newsfork.com/contact";
const COMMUNITY_HREF = "https://www.newsfork.com/contact";

const HELP_LINKS = [
  { label: "Browse the docs", href: "/" },
  { label: "Getting started", href: "/getting-started/" },
  { label: "API reference", href: "/v1/api/" },
  { label: "FAQ", href: "/resources/faq/" },
  { label: "Contact", href: CHAT_HREF },
  { label: "Changelog", href: "/changelog/" },
];

const SITE_ORIGIN = "https://docs.newsfork.com";
const structuredDataJson = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${SITE_ORIGIN}/#website`,
      url: SITE_ORIGIN,
      name: "Newsfork Docs",
      description:
        "User documentation for Newsfork — API reference, guides, user manual, and policies.",
      publisher: { "@type": "Organization", name: "Newsfork", url: "https://www.newsfork.com" },
    },
  ],
});
---

<div class="page sl-flex">
  <div class="header-strip" aria-hidden="true"></div>
  <header class="header"><slot name="header" /></header>
  {
    hasSidebar && (
      <nav class="sidebar" aria-label={Astro.locals.t("sidebarNav.accessibleLabel")}>
        <MobileMenuToggle {...Astro.props} />
        <div id="starlight__sidebar" class="sidebar-pane">
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>

  <div class="ask-help-wrap">
    <button
      type="button"
      id="ask-help-btn"
      class="ask-help-button"
      aria-label="Ask Help"
      aria-expanded="false"
      aria-haspopup="dialog"
    >
      <span class="ask-help-label">Ask Help</span>
    </button>
    <div
      id="ask-help-popup"
      class="ask-help-popup"
      role="dialog"
      aria-labelledby="ask-help-title"
      aria-hidden="true"
    >
      <h2 id="ask-help-title" class="ask-help-popup-title">Need a hand?</h2>
      <a href="/" class="ask-help-search" aria-label="Search documentation">
        <svg
          class="ask-help-search-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <span>Search docs</span>
      </a>
      <div class="ask-help-links">
        {
          HELP_LINKS.map(({ label, href }) => (
            <a
              href={href}
              class="ask-help-link"
              target={href.startsWith("http") ? "_blank" : undefined}
              rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
            >
              {label}
            </a>
          ))
        }
      </div>
      <p class="ask-help-communities-label">Join our communities</p>
      <div class="ask-help-communities">
        <a href={COMMUNITY_HREF} class="ask-help-community-icon" aria-label="Contact Newsfork">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
          </svg>
        </a>
      </div>
      <a href={CHAT_HREF} class="ask-help-chat" target="_blank" rel="noopener noreferrer">
        <svg
          class="ask-help-chat-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
        </svg>
        Contact support
      </a>
    </div>
  </div>
  <script type="application/ld+json" set:html={structuredDataJson}></script>
</div>

<script>
  (function () {
    const btn = document.getElementById("ask-help-btn");
    const popup = document.getElementById("ask-help-popup");
    if (!btn || !popup) return;

    function open() {
      popup.classList.add("is-open");
      popup.setAttribute("aria-hidden", "false");
      btn.setAttribute("aria-expanded", "true");
    }
    function close() {
      popup.classList.remove("is-open");
      popup.setAttribute("aria-hidden", "true");
      btn.setAttribute("aria-expanded", "false");
    }
    function toggle() {
      if (popup.classList.contains("is-open")) close();
      else open();
    }

    btn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      toggle();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });

    document.addEventListener("mousedown", (e) => {
      if (!popup.contains(e.target as Node) && !btn.contains(e.target as Node)) close();
    });
  })();
</script>

<style>
  .page {
    flex-direction: column;
    min-height: 100vh;
  }

  .header-strip {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background-color: #0ea5e9;
    z-index: 11;
  }
  :global([data-theme="dark"]) .header-strip {
    background-color: #0284c7;
  }

  .header {
    z-index: var(--sl-z-index-navbar);
    position: fixed;
    inset-inline-start: 0;
    inset-block-start: 3px;
    width: 100%;
    height: var(--sl-nav-height);
    border-bottom: 1px solid var(--sl-color-hairline-shade);
    padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
    padding-inline-end: var(--sl-nav-pad-x);
    background-color: var(--sl-color-bg-nav);
  }

  :global([data-has-sidebar]) .header {
    padding-inline-end: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size));
  }

  .sidebar-pane {
    visibility: var(--sl-sidebar-visibility, hidden);
    position: fixed;
    z-index: var(--sl-z-index-menu);
    inset-block-start: calc(3px + var(--sl-nav-height));
    inset-block-end: 0;
    inset-inline-start: 0;
    width: 100%;
    background-color: var(--sl-color-black);
    overflow-y: auto;
  }

  :global([aria-expanded="true"]) ~ .sidebar-pane {
    --sl-sidebar-visibility: visible;
  }

  .sidebar-content {
    height: 100%;
    min-height: max-content;
    padding: 1rem var(--sl-sidebar-pad-x) 0;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 50rem) {
    .sidebar-content::after {
      content: "";
      padding-bottom: 1px;
    }
  }

  .main-frame {
    padding-top: calc(3px + var(--sl-nav-height) + var(--sl-mobile-toc-height));
    padding-inline-start: var(--sl-content-inline-start);
  }

  .ask-help-wrap {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 999;
  }

  .ask-help-button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    min-width: 44px;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    background-color: #6b7280;
    border: 1px solid #4b5563;
    border-radius: 9999px;
    cursor: pointer;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    transition: background-color 0.2s, box-shadow 0.2s;
  }
  .ask-help-button:hover {
    background-color: #4b5563;
  }
  :global([data-theme="dark"]) .ask-help-button {
    background-color: #4b5563;
    border-color: #6b7280;
    color: #f9fafb;
  }
  :global([data-theme="dark"]) .ask-help-button:hover {
    background-color: #6b7280;
  }

  .ask-help-label {
    white-space: nowrap;
  }

  .ask-help-popup {
    position: fixed;
    bottom: 5.5rem;
    right: 1.5rem;
    z-index: 1000;
    width: calc(100vw - 3rem);
    max-width: 24rem;
    padding: 1.25rem;
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    display: none;
  }
  .ask-help-popup.is-open {
    display: block;
  }
  :global([data-theme="dark"]) .ask-help-popup {
    background-color: #111827;
    border-color: #374151;
  }

  .ask-help-popup-title {
    margin: 0 0 1rem;
    text-align: center;
    font-size: 1.125rem;
    font-weight: 600;
    color: #111827;
  }
  :global([data-theme="dark"]) .ask-help-popup-title {
    color: #f9fafb;
  }

  .ask-help-search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding: 0.625rem 0.75rem;
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    color: #374151;
    text-decoration: none;
  }
  .ask-help-search:hover {
    background-color: #f3f4f6;
  }
  :global([data-theme="dark"]) .ask-help-search {
    background-color: #1f2937;
    border-color: #374151;
    color: #e5e7eb;
  }

  .ask-help-search-icon {
    flex-shrink: 0;
    color: #9ca3af;
  }

  .ask-help-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 1rem;
    margin-bottom: 1rem;
  }
  .ask-help-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: #d1d5db;
  }
  .ask-help-link:hover {
    color: #0ea5e9;
    text-decoration-color: #0ea5e9;
  }
  :global([data-theme="dark"]) .ask-help-link {
    color: #d1d5db;
    text-decoration-color: #4b5563;
  }
  :global([data-theme="dark"]) .ask-help-link:hover {
    color: #38bdf8;
    text-decoration-color: #38bdf8;
  }

  .ask-help-communities-label {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: #6b7280;
  }

  .ask-help-communities {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .ask-help-community-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background-color: #f3f4f6;
    border-radius: 0.5rem;
    color: #0ea5e9;
    transition: background-color 0.2s;
  }
  .ask-help-community-icon:hover {
    background-color: #e5e7eb;
  }
  :global([data-theme="dark"]) .ask-help-community-icon {
    background-color: #1f2937;
    color: #38bdf8;
  }

  .ask-help-chat {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #ffffff;
    background-color: #111827;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.2s;
  }
  .ask-help-chat:hover {
    background-color: #1f2937;
  }
  :global([data-theme="dark"]) .ask-help-chat {
    background-color: #ffffff;
    color: #111827;
  }

  .ask-help-chat-icon {
    flex-shrink: 0;
  }

  @media (min-width: 50rem) {
    :global([data-has-sidebar]) .header {
      padding-inline-end: var(--sl-nav-pad-x);
    }
    .sidebar-pane {
      --sl-sidebar-visibility: visible;
      width: 20rem;
      min-width: 20rem;
      max-width: 20rem;
      background-color: var(--sl-color-bg-sidebar);
    }
  }

  @media (min-width: 50rem) {
    :global([data-has-sidebar]) .main-frame {
      padding-inline-start: 20rem;
    }
  }
</style>
