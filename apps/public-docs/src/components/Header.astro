---
import config from "virtual:starlight/user-config";
import Search from "virtual:starlight/components/Search";
import ThemeSelect from "virtual:starlight/components/ThemeSelect";

const shouldRenderSearch =
  config.pagefind || config.components?.Search !== "@astrojs/starlight/components/Search.astro";

const siteTitleHref = Astro.props.siteTitleHref ?? "/";
const LOGO_HREF = siteTitleHref;
const GETTING_STARTED_HREF = "/getting-started/";
const GUIDES_HREF = "/v1/guides/";
const API_HREF = "/v1/api/";
---

<div class="nf-header sl-flex">
  <div class="title-wrapper sl-flex">
    <a href={LOGO_HREF} class="logo-link sl-flex" aria-label="Newsfork documentation home">
      <span class="nf-wordmark">Newsfork</span>
      <span class="docs-label">Docs</span>
    </a>
  </div>
  <nav class="nav-links sl-flex" aria-label="Main">
    <a href={GETTING_STARTED_HREF} class="nav-link">Getting Started</a>
    <a href={GUIDES_HREF} class="nav-link">Guides</a>
    <a href={API_HREF} class="nav-link">API</a>
  </nav>
  <div class="sl-flex right-group">
    <ThemeSelect {...Astro.props} />
    {shouldRenderSearch && <Search {...Astro.props} />}
  </div>
</div>

<style>
  .nf-header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .title-wrapper {
    overflow: hidden;
  }

  .logo-link {
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--sl-color-text);
  }
  .logo-link:hover .nf-wordmark,
  .logo-link:hover .docs-label {
    color: var(--sl-color-text-accent);
  }

  .nf-wordmark {
    font-family: var(--sl-font);
    font-weight: 700;
    font-size: 1.375rem;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #000000;
    white-space: nowrap;
  }
  :global([data-theme="dark"]) .nf-wordmark {
    color: #ffffff;
  }

  .docs-label {
    font-size: 1rem;
    font-weight: 700;
    color: #000000;
    white-space: nowrap;
  }
  :global([data-theme="dark"]) .docs-label {
    color: #ffffff;
  }

  .nav-links {
    gap: 1.625rem;
    align-items: center;
  }

  .nav-link {
    font-size: 1rem;
    font-weight: 700;
    color: var(--sl-color-text);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--sl-color-text-accent);
  }

  .right-group {
    gap: 1rem;
    align-items: center;
  }

  @media (max-width: 50rem) {
    .nav-links {
      display: none;
    }
  }

  @media (min-width: 50rem) {
    .nf-header {
      display: grid;
      grid-template-columns: minmax(0, auto) 1fr auto;
      align-content: center;
    }
    .nav-links {
      justify-self: end;
    }
  }
</style>
