---
import MobileTableOfContents from "virtual:starlight/components/MobileTableOfContents";
import TableOfContents from "virtual:starlight/components/TableOfContents";

const { toc } = Astro.locals.starlightRoute;
const site = Astro.site?.toString() || "https://docs.newsfork.com";
const currentUrl = Astro.url.pathname;
const fullUrl = `${site}${currentUrl.endsWith("/") ? currentUrl : currentUrl + "/"}`;
const chatGptPrompt = `Can you summarize this page: ${fullUrl}`;
const chatGptUrl = `https://chat.openai.com/?q=${encodeURIComponent(chatGptPrompt)}`;
---

{
  toc && (
    <>
      <div class="lg:sl-hidden">
        <MobileTableOfContents />
      </div>
      <div class="right-sidebar-panel sl-hidden lg:sl-block">
        <div class="sl-container">
          <TableOfContents />
          <div class="toc-actions">
            <a
              href={chatGptUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="toc-action-link"
              aria-label="Open with ChatGPT"
            >
              <span class="toc-action-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
              </span>
              Open with ChatGPT
            </a>
            <button type="button" class="toc-action-link toc-action-copy" aria-label="Copy for AI" data-copy-for-ai>
              <span class="toc-action-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </span>
              <span class="toc-action-label">Copy for AI</span>
            </button>
          </div>
        </div>
      </div>
    </>
  )
}

<script>
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest("[data-copy-for-ai]");
    if (!btn) return;
    e.preventDefault();
    const pageTitle = document.querySelector("h1")?.textContent || document.title;
    const pageUrl = window.location.href;
    const description =
      document.querySelector('meta[name="description"]')?.getAttribute("content") || "";
    const mainContent =
      document.querySelector("[data-pagefind-body]") || document.querySelector("main") || document.body;
    const textContent = mainContent?.textContent?.replace(/\s+/g, " ").trim().slice(0, 15000) || "";
    const forAI = [
      `Page: ${pageTitle}`,
      description ? `Description: ${description}` : "",
      `URL: ${pageUrl}`,
      "",
      "Content:",
      textContent,
    ]
      .filter(Boolean)
      .join("\n");
    navigator.clipboard.writeText(forAI).then(() => {
      const label = btn.querySelector(".toc-action-label");
      if (label) {
        const original = label.textContent;
        label.textContent = "Copied!";
        setTimeout(() => {
          label.textContent = original;
        }, 2000);
      }
    });
  });
</script>

<style>
  .right-sidebar-panel {
    padding: 1rem var(--sl-sidebar-pad-x);
  }
  .sl-container {
    width: calc(var(--sl-sidebar-width) - 2 * var(--sl-sidebar-pad-x));
  }
  .right-sidebar-panel :global(h2) {
    color: var(--sl-color-white);
    font-size: var(--sl-text-h5);
    font-weight: 600;
    line-height: var(--sl-line-height-headings);
    margin-bottom: 0.75rem;
  }
  .right-sidebar-panel :global(:where(a)) {
    display: block;
    font-size: var(--sl-text-sm);
    text-decoration: none;
    color: var(--sl-color-gray-3);
    overflow-wrap: anywhere;
    line-height: 1.5;
    padding-block: 0.375rem;
  }
  .right-sidebar-panel :global(:where(a):hover) {
    color: var(--sl-color-white);
  }
  .right-sidebar-panel :global(a[aria-current="true"]) {
    color: var(--sl-color-accent);
  }
  @media (min-width: 72rem) {
    .sl-container {
      max-width: calc(var(--sl-toc-width) - 2 * var(--sl-sidebar-pad-x, 1rem));
    }
  }

  .toc-actions {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sl-color-gray-5);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .toc-action-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem 0;
    line-height: 1.5;
    font-family: inherit;
  }
  .toc-action-link:hover {
    color: var(--sl-color-white);
  }
  .toc-action-icon {
    flex-shrink: 0;
    opacity: 0.8;
  }
  .toc-action-icon svg {
    display: block;
  }
</style>
