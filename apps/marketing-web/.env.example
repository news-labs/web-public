# Optional overrides for the marketing site (build-time NEXT_PUBLIC_* vars).

# Contact form — defaults to same-origin /api/contact/ (Cloudflare Pages Function).
# Override with Formspree or another endpoint if needed:
# NEXT_PUBLIC_CONTACT_FORM_ACTION=https://formspree.io/f/YOUR_FORM_ID

# Cloudflare Web Analytics beacon token (optional):
# NEXT_PUBLIC_CF_BEACON_TOKEN=your-beacon-token

# Pages Function runtime env (set in Cloudflare Dashboard, not here):
# CONTACT_TO_EMAIL=hello@newsfork.com
# CONTACT_FROM_EMAIL=noreply@newsfork.com
