{
  "name": "news-labs-web-public",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=22" },
  "pnpm": { "overrides": { "esbuild": ">=0.28.1" } },
  "scripts": {
    "dev:www": "pnpm --filter marketing-web run dev",
    "dev:docs": "pnpm --filter public-docs run dev",
    "build:www": "pnpm --filter marketing-web run build",
    "build:docs": "pnpm --filter public-docs run build",
    "verify": "pnpm --filter marketing-web run typecheck && pnpm --filter marketing-web run build",
    "deploy:www": "pnpm --filter marketing-web run deploy",
    "deploy:docs": "pnpm --filter public-docs run deploy"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
