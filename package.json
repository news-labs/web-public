{
  "name": "news-labs-web-public",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=22" },
  "pnpm": { "overrides": { "esbuild": ">=0.28.1" } },
  "scripts": {
    "dev:www": "pnpm --filter marketing-web run dev",
    "dev:docs": "pnpm --filter public-docs run dev",
    "dev:admin": "pnpm --filter admin-web-portal run dev",
    "build:www": "pnpm --filter marketing-web run build",
    "build:docs": "pnpm --filter public-docs run build",
    "build:admin": "pnpm --filter admin-web-portal run build",
    "build:admin-api": "pnpm --filter admin-web-api run build",
    "pages:build:www": "pnpm install --frozen-lockfile && pnpm --filter marketing-web run build",
    "verify": "pnpm --filter marketing-web run typecheck && pnpm --filter marketing-web run build && pnpm --filter public-docs run build",
    "deploy:www": "pnpm --filter marketing-web run deploy",
    "deploy:docs": "pnpm --filter public-docs run deploy",
    "setup:cloudflare-docs": "node scripts/setup-cloudflare-docs.mjs",
    "activate:pages-domains": "node scripts/activate-nl-pages-domains.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
